#. Application name shown in native shells and About views.
msgctxt "app.title"
msgid "LinguaMesh"
msgstr "LinguaMesh"

#. Navigation label for the text translation workspace.
msgctxt "nav.text_translation"
msgid "Text translation"
msgstr "Text translation"

#. Primary action that starts a translation.
msgctxt "action.translate"
msgid "Translate"
msgstr "Translate"

#. Action that cancels the active operation.
msgctxt "action.cancel"
msgid "Cancel"
msgstr "Cancel"

#. Identifies the provider that will receive the next request.
#, python-brace-format
msgctxt "provider.active"
msgid "Active provider: {provider}"
msgstr "Active provider: {provider}"

#. Progress summary for translated document segments.
#, python-brace-format
msgctxt "translation.progress"
msgid "{completed} of {total} segments translated"
msgstr "{completed} of {total} segments translated"

#. Number of files selected for a document translation job.
#, python-brace-format
msgctxt "document.file_count"
msgid "{count} file"
msgid_plural "{count} files"
msgstr[0] "{count} file"
msgstr[1] "{count} files"

#. Explains the selected history persistence mode.
#, python-brace-format
msgctxt "history.mode[disabled]"
msgid "History is disabled"
msgstr "History is disabled"

#. Explains the selected history persistence mode.
#, python-brace-format
msgctxt "history.mode[enabled]"
msgid "History is saved on this device"
msgstr "History is saved on this device"

#. Explains the selected history persistence mode.
#, python-brace-format
msgctxt "history.mode[incognito]"
msgid "Incognito mode does not save this translation"
msgstr "Incognito mode does not save this translation"

#. Authentication error that names the affected provider without exposing credentials.
#, python-brace-format
msgctxt "error.authentication_failed"
msgid "Check the credentials for {provider} and try again."
msgstr "Check the credentials for {provider} and try again."

#. Retry guidance after a provider rate limit.
#, python-brace-format
msgctxt "error.rate_limited"
msgid "Try again in {seconds} second."
msgid_plural "Try again in {seconds} seconds."
msgstr[0] "Try again in {seconds} second."
msgstr[1] "Try again in {seconds} seconds."

#. Screen-reader label for stopping an active translation.
msgctxt "accessibility.stop_translation"
msgid "Stop translation"
msgstr "Stop translation"

#. Names the active interface language in Settings.
#, python-brace-format
msgctxt "locale.current"
msgid "Interface language: {language}"
msgstr "Interface language: {language}"

#. Actionable error shown when a remote provider cannot be reached.
msgctxt "error.network_unavailable"
msgid "Check your network connection and try again."
msgstr "Check your network connection and try again."

#. Heading for the initial provider setup screen.
msgctxt "onboarding.title"
msgid "Connect a translation provider"
msgstr "Connect a translation provider"

#. Privacy explanation shown during initial provider setup.
msgctxt "onboarding.description"
msgid "Your content goes directly to the provider you configure. LinguaMesh never bundles an API key."
msgstr "Your content goes directly to the provider you configure. LinguaMesh never bundles an API key."

#. Label for the provider profile name field.
msgctxt "provider.name"
msgid "Provider name"
msgstr "Provider name"

#. Label for the provider endpoint field.
msgctxt "field.endpoint"
msgid "Endpoint"
msgstr "Endpoint"

#. Label for the provider model field.
msgctxt "field.model"
msgid "Model"
msgstr "Model"

#. Label for the optional provider API key field.
msgctxt "field.api_key"
msgid "API key (optional for local providers)"
msgstr "API key (optional for local providers)"

#. Action that validates and saves a provider profile.
msgctxt "action.save_provider"
msgid "Save provider"
msgstr "Save provider"

#. Label for the source text input field.
msgctxt "field.source_text"
msgid "Source text"
msgstr "Source text"

#. Heading for translated output.
msgctxt "field.translation"
msgid "Translation"
msgstr "Translation"

#. Heading and navigation label for application settings.
msgctxt "settings.title"
msgid "Settings"
msgstr "Settings"

#. Heading for the interface theme preference.
msgctxt "settings.theme"
msgid "Theme"
msgstr "Theme"

#. Theme option that follows the operating system setting.
msgctxt "theme.system"
msgid "System"
msgstr "System"

#. Theme option for the light color scheme.
msgctxt "theme.light"
msgid "Light"
msgstr "Light"

#. Theme option for the dark color scheme.
msgctxt "theme.dark"
msgid "Dark"
msgstr "Dark"

#. Heading for the interface language preference.
msgctxt "settings.ui_language"
msgid "Interface language"
msgstr "Interface language"

#. Label for the translation target language selector.
msgctxt "settings.target_language"
msgid "Target language"
msgstr "Target language"

#. Status shown when the translator is ready for input.
msgctxt "status.ready"
msgid "Ready"
msgstr "Ready"

#. Status shown while translated output is streaming.
msgctxt "status.translating"
msgid "Translating…"
msgstr "Translating…"

#. Status shown after cancellation when partial output remains available.
msgctxt "status.cancelled"
msgid "Translation cancelled. Partial output was kept."
msgstr "Translation cancelled. Partial output was kept."

#. Validation error for an incomplete provider profile.
msgctxt "error.invalid_profile"
msgid "Enter a provider name, endpoint, and model."
msgstr "Enter a provider name, endpoint, and model."

#. Authentication guidance that does not expose credential content.
msgctxt "error.authentication"
msgid "Check the provider credential and try again."
msgstr "Check the provider credential and try again."

#. Error shown when the native core contract is incompatible.
msgctxt "error.incompatible_core"
msgid "This app requires a compatible LinguaMesh Core library."
msgstr "This app requires a compatible LinguaMesh Core library."

#. Fallback translation error with actionable diagnostic guidance.
msgctxt "error.unknown"
msgid "Translation failed. Review diagnostics and try again."
msgstr "Translation failed. Review diagnostics and try again."

#. Heading for non-sensitive compatibility diagnostics.
msgctxt "diagnostics.title"
msgid "Diagnostics"
msgstr "Diagnostics"

#. Summary of the loaded core ABI and protocol revisions.
#, python-brace-format
msgctxt "diagnostics.summary"
msgid "Core ABI {core_abi} · Protocol {protocol}"
msgstr "Core ABI {core_abi} · Protocol {protocol}"

#. Action that closes the settings view.
msgctxt "action.close_settings"
msgid "Close settings"
msgstr "Close settings"

#. Accessible name for the source text editor.
msgctxt "accessibility.source_content"
msgid "Text to translate"
msgstr "Text to translate"

#. Accessible name for streamed translated output.
msgctxt "accessibility.translation_output"
msgid "Streamed translation output"
msgstr "Streamed translation output"

#. Status label shown when no provider is connected.
msgctxt "status.disconnected"
msgid "Disconnected"
msgstr "Disconnected"

#. Status label shown while a provider connection is in progress.
msgctxt "status.connecting"
msgid "Connecting"
msgstr "Connecting"

#. Status label shown while cancellation is being finalized.
msgctxt "status.cancelling"
msgid "Cancelling"
msgstr "Cancelling"

#. Status label shown after a translation completes.
msgctxt "status.completed"
msgid "Completed"
msgstr "Completed"

#. Status label shown after a translation fails.
msgctxt "status.failed"
msgid "Failed"
msgstr "Failed"

#. Prefix for the compact status announcement.
msgctxt "status.label"
msgid "Status"
msgstr "Status"

#. Marker shown when a translation retains partial output.
msgctxt "status.partial_output"
msgid "Partial output"
msgstr "Partial output"

#. Status shown while the application is starting.
msgctxt "status.starting"
msgid "Starting"
msgstr "Starting"

#. Status shown while a saved provider profile is being removed.
msgctxt "status.removing_profile"
msgid "Removing saved profile"
msgstr "Removing saved profile"

#. Status shown while a discovered model selection is being confirmed.
msgctxt "status.selecting_model"
msgid "Selecting model"
msgstr "Selecting model"

#. Status label shown when the worker cannot serve requests.
msgctxt "status.unavailable"
msgid "Unavailable"
msgstr "Unavailable"

#. Primary action that opens a UTF-8 text file for translation.
msgctxt "action.open_source"
msgid "Open text file"
msgstr "Open text file"

#. Accept button in the native text-file chooser.
msgctxt "dialog.open"
msgid "Open"
msgstr "Open"

#. Title of the native text-file chooser.
msgctxt "dialog.open_text_file"
msgid "Open text file"
msgstr "Open text file"

#. Native file-filter name for supported text documents.
msgctxt "file.filter.text"
msgid "Text files"
msgstr "Text files"

#. Tooltip explaining the UTF-8 source-file import action.
msgctxt "tooltip.open_source"
msgid "Load a UTF-8 text file into the source editor"
msgstr "Load a UTF-8 text file into the source editor"

#. Heading for the Linux provider-profile configuration card.
msgctxt "section.provider_profiles"
msgid "Provider profiles"
msgstr "Provider profiles"

#. Privacy and persistence note shown in the Linux provider-profile card.
msgctxt "profile.storage_note"
msgid "Names, endpoints, model preferences, and credentials can be remembered through Secret Service. Credentials are cleared from this form immediately and remain session-only when secure storage is unavailable. Removing a saved profile does not disconnect its current session."
msgstr "Names, endpoints, model preferences, and credentials can be remembered through Secret Service. Credentials are cleared from this form immediately and remain session-only when secure storage is unavailable. Removing a saved profile does not disconnect its current session."

#. Placeholder entry for creating a new Linux provider profile.
msgctxt "profile.new"
msgid "New profile..."
msgstr "New profile..."

#. Action that removes a saved Linux provider profile.
msgctxt "action.remove_profile"
msgid "Remove saved profile"
msgstr "Remove saved profile"

#. Tooltip for choosing a saved Linux provider profile.
msgctxt "tooltip.saved_profile"
msgid "Choose a saved non-secret profile or create a new profile"
msgstr "Choose a saved non-secret profile or create a new profile"

#. Tooltip for removing the selected Linux provider profile.
msgctxt "tooltip.remove_profile"
msgid "Remove the selected saved profile without disconnecting its current session"
msgstr "Remove the selected saved profile without disconnecting its current session"

#. Tooltip for the Linux provider display-name field.
msgctxt "tooltip.provider_name"
msgid "Session-only provider display name"
msgstr "Session-only provider display name"

#. Tooltip for the Linux OpenAI-compatible endpoint field.
msgctxt "tooltip.endpoint"
msgid "HTTPS or loopback HTTP OpenAI-compatible base endpoint"
msgstr "HTTPS or loopback HTTP OpenAI-compatible base endpoint"

#. Tooltip for the Linux provider credential field.
msgctxt "tooltip.credential"
msgid "Optional credential; it is kept in memory unless remembered through Secret Service"
msgstr "Optional credential; it is kept in memory unless remembered through Secret Service"

#. Label for remembering a Linux provider profile in Secret Service.
msgctxt "option.remember_profile"
msgid "Remember profile, model, and credential in Secret Service"
msgstr "Remember profile, model, and credential in Secret Service"

#. Tooltip for remembering a Linux provider profile.
msgctxt "tooltip.remember_profile"
msgid "Save non-secret profile data and the credential through Secret Service"
msgstr "Save non-secret profile data and the credential through Secret Service"

#. Action that validates and connects a Linux provider profile.
msgctxt "action.connect"
msgid "Connect"
msgstr "Connect"

#. Label for the saved Linux provider-profile selector.
msgctxt "label.saved_profile"
msgid "Saved profile"
msgstr "Saved profile"

#. Label for the Linux source-language selector.
msgctxt "label.source_language"
msgid "Source language"
msgstr "Source language"

#. Label for the Linux provider credential field.
msgctxt "label.credential"
msgid "Credential (optional; secure when remembered)"
msgstr "Credential (optional; secure when remembered)"

#. Label for the Linux loopback provider endpoint field.
msgctxt "label.endpoint_loopback"
msgid "Endpoint (loopback example)"
msgstr "Endpoint (loopback example)"

#. Placeholder entry shown before a Linux model is selected.
msgctxt "option.model.select"
msgid "Select a model..."
msgstr "Select a model..."

#. Automatic source-language option for Linux translation.
msgctxt "option.source.auto"
msgid "Auto"
msgstr "Auto"

#. English source-language option for Linux translation.
msgctxt "option.source.english"
msgid "English"
msgstr "English"

#. Chinese source-language option for Linux translation.
msgctxt "option.source.chinese"
msgid "Chinese"
msgstr "Chinese"

#. Simplified Chinese target-language option for Linux translation.
msgctxt "option.target.chinese_simplified"
msgid "Chinese (Simplified)"
msgstr "Chinese (Simplified)"

#. English target-language option for Linux translation.
msgctxt "option.target.english"
msgid "English"
msgstr "English"

#. Japanese target-language option for Linux translation.
msgctxt "option.target.japanese"
msgid "Japanese"
msgstr "Japanese"

#. Linux provider-setup stage title while the worker starts.
msgctxt "onboarding.stage.starting"
msgid "Provider setup · Starting"
msgstr "Provider setup · Starting"

#. Linux provider-setup stage title when the worker is unavailable.
msgctxt "onboarding.stage.unavailable"
msgid "Provider setup · Unavailable"
msgstr "Provider setup · Unavailable"

#. Linux provider-setup stage title while the user configures a profile.
msgctxt "onboarding.stage.configure"
msgid "Provider setup · Step 1 of 2"
msgstr "Provider setup · Step 1 of 2"

#. Linux provider-setup stage title while a provider connects.
msgctxt "onboarding.stage.connecting"
msgid "Provider setup · Connecting"
msgstr "Provider setup · Connecting"

#. Linux provider-setup stage title while a model is selected.
msgctxt "onboarding.stage.select_model"
msgid "Provider setup · Step 2 of 2"
msgstr "Provider setup · Step 2 of 2"

#. Linux provider-setup stage title after provider and model readiness.
msgctxt "onboarding.stage.ready"
msgid "Provider setup · Ready"
msgstr "Provider setup · Ready"

#. Linux provider-setup explanation while startup checks run.
msgctxt "onboarding.detail.starting"
msgid "Checking profile storage and starting the local validation provider. No provider connection is made automatically."
msgstr "Checking profile storage and starting the local validation provider. No provider connection is made automatically."

#. Linux provider-setup explanation when the worker is unavailable.
msgctxt "onboarding.detail.unavailable"
msgid "The core worker is unavailable. Restart the application and review any error below; no provider request can be sent."
msgstr "The core worker is unavailable. Restart the application and review any error below; no provider request can be sent."

#. Linux provider-setup warning when saved profile storage is unavailable.
msgctxt "onboarding.detail.storage_unavailable"
msgid "Saved profile storage is unavailable. Configure a provider below and leave Remember off; credentials stay in memory for this session only."
msgstr "Saved profile storage is unavailable. Configure a provider below and leave Remember off; credentials stay in memory for this session only."

#. Linux provider-setup explanation when no saved profile exists.
msgctxt "onboarding.detail.configure_empty"
msgid "Create a provider profile below, enter a credential only if required, then choose Connect. Remembering uses Secret Service; otherwise the credential remains in memory for this session only."
msgstr "Create a provider profile below, enter a credential only if required, then choose Connect. Remembering uses Secret Service; otherwise the credential remains in memory for this session only."

#. Linux provider-setup explanation when saved profiles exist.
msgctxt "onboarding.detail.configure_saved"
msgid "Choose a saved profile below, re-enter its credential if required, then choose Connect. Restored profiles never connect automatically."
msgstr "Choose a saved profile below, re-enter its credential if required, then choose Connect. Restored profiles never connect automatically."

#. Linux provider-setup explanation while a named provider connects.
#, python-brace-format
msgctxt "onboarding.detail.connecting"
msgid "Validating {provider} [{profile_id}] and discovering models. The previous active provider remains unchanged until this succeeds."
msgstr "Validating {provider} [{profile_id}] and discovering models. The previous active provider remains unchanged until this succeeds."

#. Linux provider-setup explanation while model discovery completes.
msgctxt "onboarding.detail.connecting_generic"
msgid "Validating the provider and discovering models. The previous active provider remains unchanged until this succeeds."
msgstr "Validating the provider and discovering models. The previous active provider remains unchanged until this succeeds."

#. Linux provider-setup explanation before a discovered model is confirmed.
msgctxt "onboarding.detail.select_model"
msgid "Choose a discovered model. Translation remains disabled until the selection is confirmed."
msgstr "Choose a discovered model. Translation remains disabled until the selection is confirmed."

#. Linux provider-setup explanation while a named model is committed.
#, python-brace-format
msgctxt "onboarding.detail.confirm_model"
msgid "Confirming model {model}. Translation remains disabled until this selection is committed."
msgstr "Confirming model {model}. Translation remains disabled until this selection is committed."

#. Linux provider-setup summary naming the next provider and model.
#, python-brace-format
msgctxt "onboarding.detail.ready"
msgid "Next request: {provider} · {model}. Use the saved-profile list and Connect to switch deliberately."
msgstr "Next request: {provider} · {model}. Use the saved-profile list and Connect to switch deliberately."

#. Linux provider-setup warning appended when persistence is unavailable.
msgctxt "onboarding.detail.persistence_warning"
msgid "Saved profile storage is unavailable; profile persistence is disabled, Remember stays off, and credentials remain session only."
msgstr "Saved profile storage is unavailable; profile persistence is disabled, Remember stays off, and credentials remain session only."

#. Announced below the locale selector while draft translations are active.
msgctxt "locale.note.drafts"
msgid "Simplified Chinese resources are loaded from the pinned runtime catalog; translations remain unreviewed drafts."
msgstr "Simplified Chinese resources are loaded from the pinned runtime catalog; translations remain unreviewed drafts."

#. Notification body shown when a translation completes.
msgctxt "notification.body"
msgid "The translated output is ready in LinguaMesh."
msgstr "The translated output is ready in LinguaMesh."

#. Notification title shown when a translation completes.
msgctxt "notification.title"
msgid "Translation complete"
msgstr "Translation complete"

#. Active and pending provider summary with persistence modes.
#, python-brace-format
msgctxt "provider.active_pending"
msgid "Active provider remains {active} ({active_mode}); connecting {pending} ({pending_mode})."
msgstr "Active provider remains {active} ({active_mode}); connecting {pending} ({pending_mode})."

#. Pending provider connection summary.
#, python-brace-format
msgctxt "provider.connecting"
msgid "Connecting {provider} ({mode})."
msgstr "Connecting {provider} ({mode})."

#. No-provider summary explaining session-only credential behavior.
msgctxt "provider.disconnected"
msgid "No provider connected. Credentials stay session-only unless remembered through Secret Service."
msgstr "No provider connected. Credentials stay session-only unless remembered through Secret Service."

#. Persistence mode shown for a pending provider that will be remembered.
msgctxt "provider.mode.pending_saved"
msgid "will be saved with Secret Service credential protection when supplied"
msgstr "will be saved with Secret Service credential protection when supplied"

#. Persistence mode shown for an active saved provider.
msgctxt "provider.mode.saved"
msgid "saved"
msgstr "saved"

#. Persistence mode shown for a session-only provider.
msgctxt "provider.mode.session"
msgid "session only"
msgstr "session only"

#. Restored profile summary prompting deliberate connection.
msgctxt "provider.saved_restored"
msgid "Saved non-secret profiles were restored. Choose one, enter its credential if required, then connect."
msgstr "Saved non-secret profiles were restored. Choose one, enter its credential if required, then connect."

#. The active provider ID is unavailable.
msgctxt "error.active_provider_unavailable"
msgid "The active provider ID is unavailable."
msgstr "The active provider ID is unavailable."

#. The selected text file could not be opened.
msgctxt "error.file_open"
msgid "The selected text file could not be opened."
msgstr "The selected text file could not be opened."

#. The selected text file could not be read.
msgctxt "error.file_read"
msgid "The selected text file could not be read."
msgstr "The selected text file could not be read."

#. The selected text file exceeds the 4 MiB limit.
msgctxt "error.file_too_large"
msgid "The selected text file exceeds the 4 MiB limit."
msgstr "The selected text file exceeds the 4 MiB limit."

#. The selected provider profile is disabled.
msgctxt "error.profile_disabled"
msgid "The selected provider profile is disabled."
msgstr "The selected provider profile is disabled."

#. The selected saved profile is unavailable.
msgctxt "error.profile_unavailable"
msgid "The selected saved profile is unavailable."
msgstr "The selected saved profile is unavailable."

#. Enter a provider endpoint.
msgctxt "error.provider_endpoint_required"
msgid "Enter a provider endpoint."
msgstr "Enter a provider endpoint."

#. Enter a provider name.
msgctxt "error.provider_name_required"
msgid "Enter a provider name."
msgstr "Enter a provider name."

#. The core worker disconnected.
msgctxt "error.worker_disconnected"
msgid "The core worker disconnected."
msgstr "The core worker disconnected."

#. The core worker stopped.
msgctxt "error.worker_stopped"
msgid "The core worker stopped."
msgstr "The core worker stopped."
